{
  "compilerOptions": {
    "target": "es2024",
    "lib": [
      "es2024"
    ],
    "types": [
      "@cloudflare/workers-types",
      "./worker-configuration.d.ts"
    ],
    "jsx": "react-jsx",
    "module": "es2022",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  }
}
